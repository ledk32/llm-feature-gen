# Include package source and metadata
recursive-include src *.py
recursive-include src *.txt
include pyproject.toml
include README.md
include LICENSE
recursive-include examples *

# Exclude local data folders – these must never be bundled into the sdist
prune discover_images
prune discover_tabular
prune discover_texts
prune discover_videos
prune images
prune outputs
prune tabular
prune texts
prune videos
